---
import Layout from "../layouts/Layout.astro";
import db from "../db/index.js";

const { user } = Astro.locals;

if (!user || user.role !== "admin") {
	return Astro.redirect("/");
}

// Fetch all users
const usersRes = await db.execute("SELECT id, username, display_name, avatar_url, role FROM user ORDER BY username ASC");
const allUsers = usersRes.rows;

// Fetch all rolls
const rollsRes = await db.execute(`
	SELECT r.id, r.date, r.die1, r.die2, r.die3, r.die4, u.username, u.display_name, u.avatar_url 
	FROM roll r 
	JOIN user u ON r.user_id = u.id 
	ORDER BY r.date DESC, r.id DESC
	LIMIT 50
`);
const recentRolls = rollsRes.rows;

// Fetch global settings
const settingsRes = await db.execute("SELECT key, value FROM settings");
const settingsMap = new Map();
settingsRes.rows.forEach((s: any) => settingsMap.set(s.key, s.value));
---

<Layout>
	<div class="space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-700 ease-out">
		<header class="text-center md:text-left flex flex-col md:flex-row justify-between items-center gap-4 border-b border-foreground/5 pb-8">
			<div>
				<h2 class="text-3xl font-black text-foreground tracking-tight"><i class="fa-solid fa-screwdriver-wrench text-primary mr-2"></i> Centro de Control</h2>
				<p class="text-foreground/60 mt-1">Gestión avanzada de jugadores y manipulación del destino.</p>
			</div>
            <div class="bg-primary/10 px-4 py-2 rounded-full text-sm font-bold text-primary">
                Modo Administrador
            </div>
		</header>

		<!-- Global Settings Section -->
		<section class="bg-background border border-foreground/10 p-1 rounded-3xl shadow-lg">
            <div class="p-6 md:p-8">
			    <h3 class="text-xl font-bold mb-6 flex items-center gap-2"><i class="fa-solid fa-globe text-accent"></i> Configuración Global</h3>
			    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <form method="post" action="/api/admin/save-settings" class="space-y-4">
                        <div>
                            <label class="block text-sm font-bold mb-1 text-foreground/80">Último Lomito Manual</label>
                            <input type="date" name="last_lomito_date" value={settingsMap.get('last_lomito_date') || ''} class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground" />
                            <p class="text-xs text-foreground/50 mt-1">Al configurarla, esta fecha se usa para el contador de días.</p>
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-1 text-foreground/80">Clave Maestra (Recuperación)</label>
                            <input type="text" name="master_key" value={settingsMap.get('master_key') || ''} placeholder="Ej: Lomito123" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground" />
                            <p class="text-xs text-foreground/50 mt-1">Usada en /recover para resetear contraseñas de cualquier usuario.</p>
                        </div>
                        <button class="w-full bg-accent text-background font-bold py-3 rounded-xl hover:opacity-90 transition-opacity">
                            Guardar Configuración
                        </button>
                    </form>
                </div>
            </div>
		</section>

		<!-- Users Section -->
		<section class="bg-background border border-foreground/10 p-1 rounded-3xl shadow-lg">
            <div class="p-6 md:p-8">
			    <h3 class="text-xl font-bold mb-6 flex items-center gap-2"><i class="fa-solid fa-users text-secondary"></i> Padrón de Jugadores</h3>
			    <div class="overflow-x-auto rounded-2xl border border-foreground/5">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-foreground/5 text-foreground/70 uppercase tracking-wider text-xs">
                                <th class="p-4 font-bold">Jugador</th>
                                <th class="p-4 font-bold">Rol</th>
                                <th class="p-4 font-bold text-right">Acciones Peligrosas</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-foreground/5">
                            {allUsers.map((u) => (
                                <tr class="hover:bg-foreground/[0.02] transition-colors">
                                    <td class="p-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-full bg-foreground/10 flex items-center justify-center font-bold text-foreground/70 overflow-hidden shadow-sm">
                                                {u.avatar_url && u.avatar_url !== 'null' ? (
                                            <img src={u.avatar_url as string} alt={u.username as string} class="w-10 h-10 rounded-full object-cover border-2 border-foreground/10" referrerpolicy="no-referrer" />
                                        ) : (
                                            <div class="w-10 h-10 rounded-full bg-secondary/10 flex items-center justify-center font-bold text-secondary border-2 border-secondary/20">{(u.username as string).charAt(0).toUpperCase()}</div>
                                        )}
                                            </div>
                                            <span class="font-bold text-foreground">{u.username}</span>
                                        </div>
                                    </td>
                                    <td class="p-4">
                                        <span class={`px-3 py-1 text-[10px] uppercase tracking-widest rounded-full font-black ${u.role === 'admin' ? 'bg-primary/10 text-primary border border-primary/20' : 'bg-secondary/10 text-secondary border border-secondary/20'}`}>
                                            {u.role}
                                        </span>
                                    </td>
                                    <td class="p-4 text-right">
                                        {u.id !== user.id ? (
                                            <div class="flex justify-end gap-2">
                                                <form method="post" action="/api/admin/toggle-role">
                                                    <input type="hidden" name="userId" value={u.id} />
                                                    <input type="hidden" name="role" value={u.role === 'admin' ? 'user' : 'admin'} />
                                                    <button class="px-3 py-1.5 bg-foreground/5 hover:bg-foreground/10 text-foreground text-xs font-bold rounded-lg transition-colors cursor-pointer">
                                                        <i class="fa-solid fa-rotate mr-1"></i> {u.role === 'admin' ? 'Revocar' : 'Ascender'}
                                                    </button>
                                                </form>
                                                <form method="post" action="/api/admin/delete-user" onsubmit={`return confirm('⚠️ ATENCIÓN: ¿Borrar a ${u.username} y todo su historial? Esta acción es irreversible.')`}>
                                                    <input type="hidden" name="userId" value={u.id} />
                                                    <button class="px-3 py-1.5 bg-primary/10 hover:bg-primary text-primary hover:text-background text-xs font-bold rounded-lg transition-colors cursor-pointer">
                                                        <i class="fa-solid fa-trash-can"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        ) : (
                                            <span class="text-foreground/40 text-xs font-bold uppercase tracking-widest mr-2">Espejo (Vos)</span>
                                        )}
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
		</section>

		<!-- Rolls Section -->
		<section class="bg-background border border-foreground/10 p-1 rounded-3xl shadow-lg">
            <div class="p-6 md:p-8">
                <div class="flex items-center justify-between mb-6">
			        <h3 class="text-xl font-bold flex items-center gap-2"><i class="fa-solid fa-dice text-secondary"></i> Últimas 50 Tiradas</h3>
                </div>
			    <div class="overflow-x-auto rounded-2xl border border-foreground/5">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-foreground/5 text-foreground/70 uppercase tracking-wider text-xs">
                                <th class="p-4 font-bold">Fecha</th>
                                <th class="p-4 font-bold">Jugador</th>
                                <th class="p-4 font-bold">Dados</th>
                                <th class="p-4 font-bold text-right">Justicia</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-foreground/5">
                            {recentRolls.length === 0 && (
                                <tr><td colspan="4" class="p-8 text-center text-foreground/40 font-bold">La historia está en blanco.</td></tr>
                            )}
                            {recentRolls.map((r) => (
                                <tr class="hover:bg-foreground/[0.02] transition-colors">
                                    <td class="p-4 text-sm font-mono text-foreground/60">{r.date}</td>
                                    <td class="p-4">
                                        <div class="flex items-center gap-2 font-bold text-foreground">
                                            <div class="w-6 h-6 rounded-full bg-foreground/10 overflow-hidden flex items-center justify-center text-[10px]">
                                                {r.avatar_url ? (
                                                    <img src={r.avatar_url as string} alt={r.display_name as string} class="w-full h-full object-cover" />
                                                ) : (
                                                    (r.display_name as string).charAt(0).toUpperCase()
                                                )}
                                            </div>
                                            {r.display_name}
                                        </div>
                                    </td>
                                    <td class="p-4 text-lg font-mono tracking-widest text-foreground/80">
                                        {r.die1}-{r.die2}-{r.die3}-{r.die4}
                                    </td>
                                    <td class="p-4 text-right">
                                        <form method="post" action="/api/admin/delete-roll" onsubmit={`return confirm('⚠️ ¿Alterar el destino y anular la tirada de ${r.username}?')`}>
                                            <input type="hidden" name="rollId" value={r.id} />
                                            <button class="px-3 py-1.5 border border-primary/20 text-primary hover:bg-primary hover:text-background text-xs font-bold rounded-lg transition-colors cursor-pointer">
                                                <i class="fa-solid fa-ban mr-1"></i> Anular
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
		</section>
	</div>
</Layout>
