---
import Layout from "../layouts/Layout.astro";
import db from "../db/index.js";
import UserAvatar from "../components/UserAvatar.astro";
import DiceDisplay from "../components/DiceDisplay.astro";
import { getSeasonId, getPreviousSeasons, formatSeasonName } from "../utils/season.js";

const { user } = Astro.locals;

if (!user || user.role !== "admin") {
	return Astro.redirect("/");
}

// Fetch all users
const usersRes = await db.execute("SELECT id, username, display_name, avatar_url, role FROM user ORDER BY username ASC");
const allUsers = usersRes.rows;

// Fetch all exemptions
const exemptionsRes = await db.execute(`
    SELECT e.id, e.season_id, e.chore_code, u.username, u.display_name, u.avatar_url 
    FROM exemption e
    JOIN user u ON e.user_id = u.id
    ORDER BY e.season_id DESC, u.username ASC
`);
const allExemptions = exemptionsRes.rows;

// Fetch all rolls
const rollsRes = await db.execute(`
	SELECT r.id, r.date, r.die1, r.die2, r.die3, r.die4, u.username, u.display_name, u.avatar_url 
	FROM roll r 
	JOIN user u ON r.user_id = u.id 
	ORDER BY r.date DESC, r.id DESC
	LIMIT 50
`);
const recentRolls = rollsRes.rows;

// Fetch recent password resets
const resetsRes = await db.execute(`
	SELECT id, username, created_at FROM password_reset_log
	ORDER BY created_at DESC
	LIMIT 50
`);
const recentResets = resetsRes.rows;

// Format an ISO timestamp in Argentina time (GMT-3)
function formatResetDate(iso: string) {
	const d = new Date(iso);
	d.setHours(d.getHours() - 3);
	return d.toISOString().replace('T', ' ').substring(0, 16) + ' (GMT-3)';
}

// Fetch global settings
const settingsRes = await db.execute("SELECT key, value FROM settings");
const settingsMap = new Map();
settingsRes.rows.forEach((s: any) => settingsMap.set(s.key, s.value));

// Calculate current date in GMT-3 to obtain current season
const today = new Date();
today.setHours(today.getHours() - 3);
const dateStr = today.toISOString().split('T')[0];
const currentSeason = getSeasonId(dateStr);

// Get current season and last 2 seasons
const recentSeasons = getPreviousSeasons(currentSeason, 2);

// Fetch distinct season_ids present in manual_points and exemption tables
const dbSeasonsRes = await db.execute(`
    SELECT DISTINCT season_id FROM exemption
    UNION
    SELECT DISTINCT season_id FROM manual_points
`);
const dbSeasons = dbSeasonsRes.rows.map((r: any) => r.season_id).filter(Boolean);

// Combine, de-duplicate and sort (newest to oldest)
const seasonsOrder = ['verano', 'otoño', 'invierno', 'primavera'];
const uniqueSeasons = Array.from(new Set([...recentSeasons, ...dbSeasons]));
uniqueSeasons.sort((a, b) => {
    const [yearA, nameA] = a.split('-');
    const [yearB, nameB] = b.split('-');
    if (yearA !== yearB) {
        return parseInt(yearB) - parseInt(yearA);
    }
    return seasonsOrder.indexOf(nameB) - seasonsOrder.indexOf(nameA);
});
---

<Layout>
	<div class="space-y-10 animate-in fade-in duration-500 ease-out">
		<header class="text-center md:text-left flex flex-col md:flex-row justify-between items-center gap-4 border-b border-foreground/5 pb-8 animate-in fade-in slide-in-from-bottom-4 duration-500 delay-75 ease-out">
			<div>
				<h2 class="text-3xl font-black text-foreground tracking-tight"><i class="fa-solid fa-screwdriver-wrench text-primary mr-2"></i> Centro de Control</h2>
				<p class="text-foreground/60 mt-1">Gestión avanzada de jugadores y manipulación del destino.</p>
			</div>
            <div class="bg-primary/10 px-4 py-2 rounded-full text-sm font-bold text-primary">
                Modo Administrador
            </div>
		</header>

		<!-- Global Settings Section -->
		<section class="bg-white border border-foreground/10 p-1 rounded-3xl shadow-lg animate-in fade-in slide-in-from-bottom-4 duration-500 delay-100 ease-out hover-card-lift">
            <div class="p-6 md:p-8">
			    <h3 class="text-xl font-bold mb-6 flex items-center gap-2"><i class="fa-solid fa-globe text-accent"></i> Configuración Global</h3>
			    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <form method="post" action="/api/admin/save-settings" class="space-y-4">
                        <div>
                            <label class="block text-sm font-bold mb-1 text-foreground/80">Último Lomito Manual</label>
                            <input type="date" name="last_lomito_date" value={settingsMap.get('last_lomito_date') || ''} class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground" />
                            <p class="text-xs text-foreground/50 mt-1">Al configurarla, esta fecha se usa para el contador de días.</p>
                        </div>
                        <button class="w-full bg-accent text-background font-bold py-3 rounded-xl hover:opacity-90 transition-opacity cursor-pointer">
                            Guardar Configuración
                        </button>
                    </form>

                    <!-- Discord Quick Actions -->
                    <div class="space-y-4 flex flex-col justify-between border-t md:border-t-0 md:border-l border-foreground/10 pt-6 md:pt-0 md:pl-8">
                        <div>
                            <h4 class="text-sm font-bold uppercase tracking-wider text-foreground/70 mb-2">Notificaciones de Discord</h4>
                            <p class="text-xs text-foreground/50 leading-relaxed mb-4">
                                Publica manualmente el veredicto oficial del día de hoy en el canal de Discord. Esto asignará los roles definitivos (quién lava, quién saca y quién pone) basados en la suerte de hoy.
                            </p>
                        </div>
                        <div class="space-y-3">
                            <button id="publish-verdict-btn" class="w-full bg-secondary text-background font-bold py-3.5 rounded-xl hover:opacity-90 transition-all flex items-center justify-center gap-2 cursor-pointer shadow-md shadow-secondary/15">
                                <i class="fa-solid fa-bullhorn"></i> Publicar Veredicto Final
                            </button>
                            <p id="publish-verdict-status" class="text-xs font-semibold text-center hidden"></p>
                        </div>
                    </div>
                </div>
            </div>
		</section>

		<!-- Users Section -->
		<section class="bg-white border border-foreground/10 p-1 rounded-3xl shadow-lg animate-in fade-in slide-in-from-bottom-4 duration-500 delay-150 ease-out hover-card-lift">
            <div class="p-6 md:p-8">
			    <h3 class="text-xl font-bold mb-6 flex items-center gap-2"><i class="fa-solid fa-users text-secondary"></i> Padrón de Jugadores</h3>
			    <div class="overflow-x-auto rounded-2xl border border-foreground/5">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-foreground/5 text-foreground/70 uppercase tracking-wider text-xs">
                                <th class="p-4 font-bold">Jugador</th>
                                <th class="p-4 font-bold">Rol</th>
                                <th class="p-4 font-bold text-right">Acciones Peligrosas</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-foreground/5">
                            {allUsers.map((u) => (
                                <tr class="hover:bg-foreground/[0.02] transition-colors">
                                    <td class="p-4">
                                        <div class="flex items-center gap-3">
                                            <div class="relative group cursor-pointer" onclick={`document.getElementById('avatar-input-${u.id}').click()`} title="Hacer clic para cambiar foto de perfil">
                                                <UserAvatar user={u as any} size="md" />
                                                <div class="absolute inset-0 bg-foreground/45 rounded-full flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                                                    <i class="fa-solid fa-camera text-background text-[10px]"></i>
                                                </div>
                                            </div>
                                            <input type="file" id={`avatar-input-${u.id}`} data-user-id={u.id} accept="image/*" class="hidden admin-avatar-input" />
                                            {u.avatar_url && !u.avatar_url.includes('api.dicebear.com') && (
                                                <button class="remove-user-avatar-btn text-foreground/30 hover:text-primary p-1 rounded-md transition-colors cursor-pointer" data-user-id={u.id} title="Quitar foto de perfil y volver al avatar por defecto">
                                                    <i class="fa-solid fa-trash-can text-xs"></i>
                                                </button>
                                            )}
                                            <span class="font-bold text-foreground">{u.username}</span>
                                        </div>
                                    </td>
                                    <td class="p-4">
                                        <span class={`px-3 py-1 text-[10px] uppercase tracking-widest rounded-full font-black ${u.role === 'admin' ? 'bg-primary/10 text-primary border border-primary/20' : 'bg-secondary/10 text-secondary border border-secondary/20'}`}>
                                            {u.role}
                                        </span>
                                    </td>
                                    <td class="p-4 text-right">
                                        {u.id !== user.id ? (
                                            <div class="flex justify-end gap-2">
                                                <form method="post" action="/api/admin/toggle-role">
                                                    <input type="hidden" name="userId" value={u.id} />
                                                    <input type="hidden" name="role" value={u.role === 'admin' ? 'user' : 'admin'} />
                                                    <button class="px-3 py-1.5 bg-foreground/5 hover:bg-foreground/10 text-foreground text-xs font-bold rounded-lg transition-colors cursor-pointer">
                                                        <i class="fa-solid fa-rotate mr-1"></i> {u.role === 'admin' ? 'Revocar' : 'Ascender'}
                                                    </button>
                                                </form>
                                                <form method="post" action="/api/admin/delete-user" onsubmit={`return confirm('⚠️ ATENCIÓN: ¿Borrar a ${u.username} y todo su historial? Esta acción es irreversible.')`}>
                                                    <input type="hidden" name="userId" value={u.id} />
                                                    <button class="px-3 py-1.5 bg-primary/10 hover:bg-primary text-primary hover:text-background text-xs font-bold rounded-lg transition-colors cursor-pointer">
                                                        <i class="fa-solid fa-trash-can"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        ) : (
                                            <span class="text-foreground/40 text-xs font-bold uppercase tracking-widest mr-2">Espejo (Vos)</span>
                                        )}
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
		</section>

		<!-- Manual Points Section -->
		<section class="bg-white border border-foreground/10 p-1 rounded-3xl shadow-lg mt-8 mb-8 animate-in fade-in slide-in-from-bottom-4 duration-500 delay-200 ease-out hover-card-lift">
            <div class="p-6 md:p-8">
			    <h3 class="text-xl font-bold mb-6 flex items-center gap-2"><i class="fa-solid fa-pen-to-square text-accent"></i> Carga Histórica de Puntos</h3>
			    <div class="grid grid-cols-1 gap-8">
                    <form method="post" action="/api/admin/manual-points" class="space-y-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
                            <div>
                                <label class="block text-sm font-bold mb-1 text-foreground/80">Jugador</label>
                                <select name="user_id" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground" required>
                                    <option value="">Seleccionar...</option>
                                    {allUsers.map(u => (
                                        <option value={u.id}>{u.display_name || u.username}</option>
                                    ))}
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-bold mb-1 text-foreground/80">Temporada</label>
                                <select name="season_id" id="season-select" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground" required>
                                    <option value="">Seleccionar...</option>
                                    {uniqueSeasons.map(s => (
                                        <option value={s}>{formatSeasonName(s)}</option>
                                    ))}
                                    <option value="custom">Otra temporada (escribir)...</option>
                                </select>
                                <div id="custom-season-container" class="hidden mt-2">
                                    <input type="text" name="custom_season_id" id="custom-season-input" placeholder="Ej: 2025-invierno" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground text-sm" />
                                    <p class="text-[10px] text-foreground/50 mt-1">Formato: AAAA-estación (verano, otoño, invierno, primavera)</p>
                                </div>
                            </div>
                            <div>
                                <label class="block text-sm font-bold mb-1 text-foreground/80">Tarea</label>
                                <select name="chore_code" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground" required>
                                    <option value="">Seleccionar...</option>
                                    <option value="LA">Lavar (LA)</option>
                                    <option value="SA">Sacar (SA)</option>
                                    <option value="PO">Poner (PO)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-bold mb-1 text-foreground/80">Puntos Totales</label>
                                <input type="number" name="points" min="0" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground" placeholder="Ej: 5" required />
                            </div>
                        </div>
                        <button class="w-full bg-accent text-background font-bold py-3 rounded-xl hover:opacity-90 transition-opacity mt-2 cursor-pointer">
                            Cargar Puntos
                        </button>
                    </form>
                </div>
            </div>
		</section>

		<!-- Exemptions Section -->
		<section class="bg-white border border-foreground/10 p-1 rounded-3xl shadow-lg mt-8 mb-8 animate-in fade-in slide-in-from-bottom-4 duration-500 delay-300 ease-out hover-card-lift">
            <div class="p-6 md:p-8 border-b border-foreground/5 mb-6">
                <h3 class="text-xl font-bold flex items-center gap-2"><i class="fa-solid fa-shield-halved text-secondary"></i> Gestión de Exenciones</h3>
                <p class="text-xs text-foreground/50 mt-1">Configura qué jugadores están exentos de realizar tareas específicas en cada temporada.</p>
            </div>
            
            <div class="px-6 md:px-8 pb-8 space-y-8">
                <!-- Add Exemption Form -->
                <form method="post" action="/api/admin/add-exemption" class="space-y-4 bg-foreground/[0.02] border border-foreground/5 p-5 rounded-2xl">
                    <h4 class="text-sm font-bold uppercase tracking-wider text-foreground/70 mb-2">Crear Nueva Exención</h4>
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div>
                            <label class="block text-sm font-bold mb-1 text-foreground/80">Jugador</label>
                            <select name="user_id" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground text-sm" required>
                                <option value="">Seleccionar...</option>
                                {allUsers.map(u => (
                                    <option value={u.id}>{u.display_name || u.username}</option>
                                ))}
                            </select>
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-1 text-foreground/80">Temporada</label>
                            <select name="season_id" id="exemption-season-select" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground text-sm" required>
                                <option value="">Seleccionar...</option>
                                {uniqueSeasons.map(s => (
                                    <option value={s}>{formatSeasonName(s)}</option>
                                ))}
                                <option value="custom">Otra temporada (escribir)...</option>
                            </select>
                            <div id="exemption-custom-season-container" class="hidden mt-2">
                                <input type="text" name="custom_season_id" id="exemption-custom-season-input" placeholder="Ej: 2026-otoño" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground text-sm" />
                                <p class="text-[10px] text-foreground/50 mt-1">Formato: AAAA-estación (verano, otoño, invierno, primavera)</p>
                            </div>
                        </div>
                        <div>
                            <label class="block text-sm font-bold mb-1 text-foreground/80">Tarea Exenta</label>
                            <select name="chore_code" class="w-full bg-foreground/5 border border-foreground/10 rounded-xl p-3 text-foreground text-sm" required>
                                <option value="">Seleccionar...</option>
                                <option value="LA">Lavar (LA) 🧽</option>
                                <option value="SA">Sacar (SA) 🗑️</option>
                                <option value="PO">Poner (PO) 🍽️</option>
                            </select>
                        </div>
                    </div>
                    <button class="bg-secondary text-background font-bold px-6 py-2.5 rounded-xl hover:opacity-90 transition-opacity mt-2 text-sm shadow-sm cursor-pointer">
                        Asignar Exención
                    </button>
                </form>

                <!-- List of Exemptions -->
                <div>
                    <h4 class="text-sm font-bold uppercase tracking-wider text-foreground/70 mb-4">Exenciones Registradas</h4>
                    {allExemptions.length === 0 ? (
                        <p class="text-sm text-foreground/40 italic py-4">No hay exenciones cargadas en la base de datos.</p>
                    ) : (
                        <div class="overflow-x-auto rounded-2xl border border-foreground/5">
                            <table class="w-full text-left border-collapse whitespace-nowrap text-sm">
                                <thead>
                                    <tr class="bg-foreground/5 text-foreground/70 uppercase tracking-wider text-xs">
                                        <th class="p-4 font-bold">Temporada</th>
                                        <th class="p-4 font-bold">Jugador</th>
                                        <th class="p-4 font-bold">Tarea Exenta</th>
                                        <th class="p-4 font-bold text-right">Acciones</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-foreground/5">
                                    {allExemptions.map((ex: any) => {
                                        const choreEmoji = ex.chore_code === 'LA' ? '🧽' : ex.chore_code === 'SA' ? '🗑️' : '🍽️';
                                        const choreLabel = ex.chore_code === 'LA' ? 'Lavar' : ex.chore_code === 'SA' ? 'Sacar' : 'Poner';
                                        return (
                                            <tr class="hover:bg-foreground/[0.02] transition-colors">
                                                <td class="p-4 font-bold text-foreground/70">{formatSeasonName(ex.season_id)}</td>
                                                <td class="p-4">
                                                    <div class="flex items-center gap-2 font-bold text-foreground">
                                                        <UserAvatar user={{ username: ex.username, display_name: ex.display_name, avatar_url: ex.avatar_url }} size="sm" />
                                                        {ex.display_name}
                                                    </div>
                                                </td>
                                                <td class="p-4">
                                                    <span class="font-bold text-secondary">{choreEmoji} Exento de {choreLabel} ({ex.chore_code})</span>
                                                </td>
                                                <td class="p-4 text-right">
                                                    <form method="post" action="/api/admin/remove-exemption" onsubmit={`return confirm('⚠️ ¿Eliminar la exención de ${ex.display_name} para ${formatSeasonName(ex.season_id)}?')`}>
                                                        <input type="hidden" name="id" value={ex.id} />
                                                        <button class="px-3 py-1.5 border border-primary/20 hover:bg-primary text-primary hover:text-background text-xs font-bold rounded-lg transition-colors cursor-pointer">
                                                            <i class="fa-solid fa-trash mr-1"></i> Eliminar
                                                        </button>
                                                    </form>
                                                </td>
                                            </tr>
                                        );
                                    })}
                                </tbody>
                            </table>
                        </div>
                    )}
                </div>
            </div>
		</section>

		<!-- Rolls Section -->
		<section class="bg-white border border-foreground/10 p-1 rounded-3xl shadow-lg animate-in fade-in slide-in-from-bottom-4 duration-500 delay-[350ms] ease-out hover-card-lift">
            <div class="p-6 md:p-8">
                <div class="flex items-center justify-between mb-6">
			        <h3 class="text-xl font-bold flex items-center gap-2"><i class="fa-solid fa-dice text-secondary"></i> Últimas 50 Tiradas</h3>
                </div>
			    <div class="overflow-x-auto rounded-2xl border border-foreground/5">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-foreground/5 text-foreground/70 uppercase tracking-wider text-xs">
                                <th class="p-4 font-bold">Fecha</th>
                                <th class="p-4 font-bold">Jugador</th>
                                <th class="p-4 font-bold">Dados</th>
                                <th class="p-4 font-bold text-right">Justicia</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-foreground/5">
                            {recentRolls.length === 0 && (
                                <tr><td colspan="4" class="p-8 text-center text-foreground/40 font-bold">La historia está en blanco.</td></tr>
                            )}
                            {recentRolls.map((r) => (
                                <tr class="hover:bg-foreground/[0.02] transition-colors">
                                    <td class="p-4 text-sm font-mono text-foreground/60">{r.date}</td>
                                    <td class="p-4">
                                        <div class="flex items-center gap-2 font-bold text-foreground">
                                            <UserAvatar user={{ username: r.username as string, display_name: r.display_name as string, avatar_url: r.avatar_url as string }} size="sm" />
                                            {r.display_name}
                                        </div>
                                    </td>
                                    <td class="p-4">
                                        <DiceDisplay die1={r.die1 as number} die2={r.die2 as number} die3={r.die3 as number} die4={r.die4 as number} size="md" />
                                    </td>
                                    <td class="p-4 text-right">
                                        <form method="post" action="/api/admin/delete-roll" onsubmit={`return confirm('⚠️ ¿Alterar el destino y anular la tirada de ${r.username}?')`}>
                                            <input type="hidden" name="rollId" value={r.id} />
                                            <button class="px-3 py-1.5 border border-primary/20 text-primary hover:bg-primary hover:text-background text-xs font-bold rounded-lg transition-colors cursor-pointer">
                                                <i class="fa-solid fa-ban mr-1"></i> Anular
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
		</section>
		<!-- Password Resets Section -->
		<section class="bg-white border border-foreground/10 p-1 rounded-3xl shadow-lg animate-in fade-in slide-in-from-bottom-4 duration-500 delay-[400ms] ease-out hover-card-lift">
            <div class="p-6 md:p-8">
                <h3 class="text-xl font-bold mb-2 flex items-center gap-2"><i class="fa-solid fa-key text-accent"></i> Cambios de Contraseña</h3>
                <p class="text-xs text-foreground/50 mb-6">Registro de restablecimientos de contraseña hechos desde /reset. Cualquiera puede resetear libremente; acá queda constancia por las dudas.</p>
			    <div class="overflow-x-auto rounded-2xl border border-foreground/5">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-foreground/5 text-foreground/70 uppercase tracking-wider text-xs">
                                <th class="p-4 font-bold">Fecha y Hora</th>
                                <th class="p-4 font-bold">Usuario</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-foreground/5">
                            {recentResets.length === 0 && (
                                <tr><td colspan="2" class="p-8 text-center text-foreground/40 font-bold">Nadie cambió su contraseña todavía.</td></tr>
                            )}
                            {recentResets.map((r: any) => (
                                <tr class="hover:bg-foreground/[0.02] transition-colors">
                                    <td class="p-4 text-sm font-mono text-foreground/60">{formatResetDate(r.created_at)}</td>
                                    <td class="p-4 font-bold text-foreground">{r.username}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            </div>
		</section>
	</div>

	<script>
		document.addEventListener('astro:page-load', () => {
			// Manual points custom season handler
			const seasonSelect = document.getElementById('season-select') as HTMLSelectElement;
			const customSeasonContainer = document.getElementById('custom-season-container');
			const customSeasonInput = document.getElementById('custom-season-input') as HTMLInputElement;

			seasonSelect?.addEventListener('change', () => {
				if (seasonSelect.value === 'custom') {
					customSeasonContainer?.classList.remove('hidden');
					customSeasonInput?.setAttribute('required', 'true');
				} else {
					customSeasonContainer?.classList.add('hidden');
					customSeasonInput?.removeAttribute('required');
				}
			});

			// Exemptions custom season handler
			const exemptionSeasonSelect = document.getElementById('exemption-season-select') as HTMLSelectElement;
			const exemptionCustomSeasonContainer = document.getElementById('exemption-custom-season-container');
			const exemptionCustomSeasonInput = document.getElementById('exemption-custom-season-input') as HTMLInputElement;

			exemptionSeasonSelect?.addEventListener('change', () => {
				if (exemptionSeasonSelect.value === 'custom') {
					exemptionCustomSeasonContainer?.classList.remove('hidden');
					exemptionCustomSeasonInput?.setAttribute('required', 'true');
				} else {
					exemptionCustomSeasonContainer?.classList.add('hidden');
					exemptionCustomSeasonInput?.removeAttribute('required');
				}
			});

			// Admin user avatar quick update handler
			const adminAvatarInputs = document.querySelectorAll('.admin-avatar-input');
			adminAvatarInputs.forEach(inputEl => {
				inputEl.addEventListener('change', async (e) => {
					const input = e.target as HTMLInputElement;
					const file = input.files?.[0];
					if (!file) return;

					const userId = input.getAttribute('data-user-id');
					if (!userId) return;

					if (!file.type.startsWith('image/')) {
						alert("Por favor selecciona una imagen válida.");
						return;
					}

					try {
						const base64Image = await compressImage(file, 256, 256, 0.8);
						const response = await fetch('/api/admin/update-user-avatar', {
							method: 'POST',
							headers: { 'Content-Type': 'application/json' },
							body: JSON.stringify({ userId, avatar: base64Image })
						});

						if (!response.ok) {
							throw new Error(await response.text());
						}
						window.location.reload();
					} catch (err: any) {
						alert(err.message || "Ocurrió un error al subir la imagen");
					}
				});
			});

			// Admin user avatar remove handler
			const removeAvatarBtns = document.querySelectorAll('.remove-user-avatar-btn');
			removeAvatarBtns.forEach(btn => {
				btn.addEventListener('click', async (e) => {
					const button = btn as HTMLButtonElement;
					const userId = button.getAttribute('data-user-id');
					if (!userId) return;

					if (confirm("¿Seguro que querés eliminar la foto de este usuario y restaurar el avatar por defecto?")) {
						try {
							const response = await fetch('/api/admin/update-user-avatar', {
								method: 'POST',
								headers: { 'Content-Type': 'application/json' },
								body: JSON.stringify({ userId, removeAvatar: true })
							});

							if (!response.ok) {
								throw new Error(await response.text());
							}
							window.location.reload();
						} catch (err: any) {
							alert(err.message || "Ocurrió un error al eliminar la imagen");
						}
					}
				});
			});

			// Publish manual verdict to Discord
			const publishVerdictBtn = document.getElementById('publish-verdict-btn');
			const publishVerdictStatus = document.getElementById('publish-verdict-status');

			publishVerdictBtn?.addEventListener('click', async () => {
				if (!confirm('¿Confirmar publicación del Veredicto Final en Discord?')) {
					return;
				}

				if (publishVerdictBtn instanceof HTMLButtonElement) {
					publishVerdictBtn.disabled = true;
				}
				if (publishVerdictStatus) {
					publishVerdictStatus.textContent = 'Enviando veredicto...';
					publishVerdictStatus.className = 'text-xs font-semibold text-center text-foreground/50 block';
				}

				try {
					const res = await fetch('/api/admin/publish-verdict', {
						method: 'POST'
					});
					const data = await res.json();

					if (res.ok && data.success) {
						if (publishVerdictStatus) {
							publishVerdictStatus.textContent = '✅ ¡Veredicto publicado exitosamente en Discord!';
							publishVerdictStatus.className = 'text-xs font-semibold text-center text-emerald-500 block';
						}
					} else {
						if (publishVerdictStatus) {
							publishVerdictStatus.textContent = `❌ Error: ${data.error || 'No se pudo publicar'}`;
							publishVerdictStatus.className = 'text-xs font-semibold text-center text-primary block';
						}
					}
				} catch (err: any) {
					if (publishVerdictStatus) {
						publishVerdictStatus.textContent = `❌ Error: ${err.message || 'Error de conexión'}`;
						publishVerdictStatus.className = 'text-xs font-semibold text-center text-primary block';
					}
				} finally {
					if (publishVerdictBtn instanceof HTMLButtonElement) {
						publishVerdictBtn.disabled = false;
					}
				}
			});
		});

		// Comprime la imagen usando un Canvas antes de enviarla
		function compressImage(file: File, maxWidth: number, maxHeight: number, quality: number): Promise<string> {
			return new Promise((resolve, reject) => {
				const reader = new FileReader();
				reader.readAsDataURL(file);
				reader.onload = (event) => {
					const img = new Image();
					img.src = event.target?.result as string;
					img.onload = () => {
						const canvas = document.createElement('canvas');
						let width = img.width;
						let height = img.height;

						if (width > height) {
							if (width > maxWidth) {
								height = Math.round(height * maxWidth / width);
								width = maxWidth;
							}
						} else {
							if (height > maxHeight) {
								width = Math.round(width * maxHeight / height);
								height = maxHeight;
							}
						}

						canvas.width = width;
						canvas.height = height;

						const ctx = canvas.getContext('2d');
						if (!ctx) {
							reject(new Error("No se pudo obtener el contexto del canvas"));
							return;
						}
						
						ctx.drawImage(img, 0, 0, width, height);
						resolve(canvas.toDataURL('image/jpeg', quality));
					};
					img.onerror = (err) => reject(err);
				};
				reader.onerror = (err) => reject(err);
			});
		}
	</script>
</Layout>
