---
import Layout from '../layouts/Layout.astro';

if (Astro.locals.user) {
	return Astro.redirect('/');
}
---

<Layout>
	<div class="max-w-md mx-auto bg-white p-8 rounded-lg shadow mt-10">
		<h2 class="text-2xl font-bold mb-2 text-center">Restablecer Contraseña</h2>
		<p class="text-sm text-gray-500 text-center mb-6">Pedile la clave maestra al administrador del juego.</p>
		<form method="post" action="/api/reset" enctype="application/x-www-form-urlencoded" class="space-y-4">
			<div>
				<label class="block text-sm font-medium mb-1">Usuario</label>
				<input type="text" name="username" class="w-full border rounded p-2" required />
			</div>
			<div>
				<label class="block text-sm font-medium mb-1">Nueva Contraseña</label>
				<input type="password" name="new_password" class="w-full border rounded p-2" required />
			</div>
			<div>
				<label class="block text-sm font-medium mb-1">Clave Maestra</label>
				<input type="password" name="master_key" class="w-full border rounded p-2" required />
			</div>
			<button type="submit" class="w-full bg-orange-600 text-white p-2 rounded hover:bg-orange-700 font-semibold transition cursor-pointer">Restablecer</button>
		</form>
		<p class="mt-4 text-center text-sm">
			<a href="/login" class="text-blue-600 hover:underline">Volver al Login</a>
		</p>
	</div>
</Layout>
