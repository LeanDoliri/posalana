---
import Layout from '../layouts/Layout.astro';
import db from '../db/index.js';
import { getSeasonId } from '../utils/season.js';

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const user = Astro.locals.user;

// Get today's date in GMT-3
const today = new Date();
today.setHours(today.getHours() - 3);
const dateStr = today.toISOString().split('T')[0];

// Check if user rolled
const userRollRes = await db.execute({
    sql: "SELECT * FROM roll WHERE user_id = ? AND date = ?",
    args: [user.id, dateStr]
});
const hasRolled = userRollRes.rows.length > 0;
const myRoll = hasRolled ? userRollRes.rows[0] : null;

// Get all rolls for today, ordered by rules
const allRollsRes = await db.execute({
    sql: `
        SELECT r.*, u.username, u.avatar_url 
        FROM roll r
        JOIN user u ON r.user_id = u.id
        WHERE r.date = ?
        ORDER BY r.die1 ASC, r.die2 ASC, r.die3 ASC, r.die4 ASC
    `,
    args: [dateStr]
});
const allRolls = allRollsRes.rows;

// Sort rolls by rules
const sortedRolls = [...allRolls].sort((a, b) => {
    if (a.die1 !== b.die1) return (a.die1 as number) - (b.die1 as number);
    if (a.die2 !== b.die2) return (a.die2 as number) - (b.die2 as number);
    if (a.die3 !== b.die3) return (a.die3 as number) - (b.die3 as number);
    return (a.die4 as number) - (b.die4 as number);
});

// Fetch current season exemptions
const currentSeason = getSeasonId(dateStr);
const exemptionsRes = await db.execute({
    sql: "SELECT user_id, chore_code FROM exemption WHERE season_id = ?",
    args: [currentSeason]
});
const exemptions = exemptionsRes.rows;

const chores = [
    { label: "LAva los platos", code: "LA", emoji: "🍽️" },
    { label: "SAca la mesa", code: "SA", emoji: "🧹" },
    { label: "POne la mesa", code: "PO", emoji: "🍴" }
];
const safeChore = { label: "NAda", code: "NA", emoji: "🎉" };

// Assign chores respecting exemptions (Option A: Shift up)
const assignedChores = new Map();
for (const roll of sortedRolls) {
    assignedChores.set(roll.id, safeChore);
}

for (const chore of chores) {
    for (const roll of sortedRolls) {
        if (assignedChores.get(roll.id) !== safeChore) continue; // Already assigned

        const isExempt = exemptions.some(e => e.user_id === roll.user_id && e.chore_code === chore.code);
        if (!isExempt) {
            assignedChores.set(roll.id, chore);
            break; // Move to the next chore
        }
    }
}

// Detect Cláusula Lomito: two rolls with exactly the same dice
let lomitoActivated = false;
let lomitoPlayers: string[] = [];
for (let i = 0; i < allRolls.length; i++) {
    for (let j = i + 1; j < allRolls.length; j++) {
        const a = allRolls[i];
        const b = allRolls[j];
        if (a.die1 === b.die1 && a.die2 === b.die2 && a.die3 === b.die3 && a.die4 === b.die4) {
            lomitoActivated = true;
            if (!lomitoPlayers.includes(a.username as string)) lomitoPlayers.push(a.username as string);
            if (!lomitoPlayers.includes(b.username as string)) lomitoPlayers.push(b.username as string);
        }
    }
}
---
<Layout>
    <div class="space-y-8">
        <section class="bg-background border border-foreground/10 p-6 rounded-lg shadow text-center">
            <h2 class="text-2xl font-bold mb-2">Tirada del Día</h2>
            <p class="text-foreground/60 mb-6">{dateStr}</p>

            {hasRolled && myRoll ? (
                <div class="inline-block bg-secondary/10 border border-secondary/20 p-4 rounded-xl">
                    <p class="text-sm text-secondary font-semibold mb-2">Tu tirada:</p>
                    <div class="flex gap-2 justify-center text-3xl">
                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(myRoll.die1 as number)-1]} text-secondary`}></i>
                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(myRoll.die2 as number)-1]} text-foreground/40 text-2xl mt-1`}></i>
                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(myRoll.die3 as number)-1]} text-foreground/40 text-2xl mt-1`}></i>
                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(myRoll.die4 as number)-1]} text-foreground/40 text-2xl mt-1`}></i>
                    </div>
                </div>
            ) : (
                <form method="post" action="/api/roll">
                    <button type="submit" class="bg-secondary text-background px-8 py-3 rounded-full text-lg font-bold hover:opacity-90 hover:scale-105 transition-transform shadow-lg cursor-pointer">
                        <i class="fa-solid fa-dice mr-2"></i> Tirar los Dados
                    </button>
                </form>
            )}
        </section>

        {lomitoActivated && (
            <section class="bg-accent/10 border-2 border-accent p-6 rounded-lg shadow text-center">
                <p class="text-3xl mb-2">🥩🎉🥩</p>
                <h3 class="text-xl font-bold text-accent">¡CLÁUSULA LOMITO ACTIVADA!</h3>
                <p class="text-accent/90 mt-2 font-semibold">{lomitoPlayers.join(" y ")} sacaron exactamente la misma tirada.</p>
                <p class="text-accent/80 mt-1">¡Se comen lomitos con papas!</p>
            </section>
        )}

        <section class="bg-background border border-foreground/10 p-6 rounded-lg shadow">
            <h3 class="text-xl font-bold mb-4 border-b border-foreground/10 pb-2">Ranking POSALANA del Día</h3>
            
            {sortedRolls.length === 0 ? (
                <p class="text-foreground/50 text-center py-4">Nadie ha tirado los dados todavía hoy.</p>
            ) : (
                <div class="space-y-3">
                    {sortedRolls.map((roll) => {
                        const chore = assignedChores.get(roll.id) || safeChore;
                        const isSafe = chore.code === 'NA';
                        return (
                            <div class={`flex items-center justify-between p-3 rounded-lg border ${isSafe ? 'bg-secondary/10 border-secondary/20' : 'bg-primary/10 border-primary/20'}`}>
                                <div class="flex items-center gap-3">
                                    <div class="w-8 h-8 rounded-full bg-foreground/10 overflow-hidden">
                                        {roll.avatar_url && <img src={roll.avatar_url as string} alt={roll.username as string} />}
                                    </div>
                                    <span class="font-semibold">{roll.username}</span>
                                    <span class={`text-xs px-2 py-1 rounded-full ml-2 font-bold ${isSafe ? 'bg-secondary text-background' : 'bg-primary text-background'}`}>{chore.code}</span>
                                </div>
                                <div class="flex items-center gap-6">
                                    <div class="flex gap-1 text-xl">
                                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(roll.die1 as number)-1]}`}></i>
                                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(roll.die2 as number)-1]} text-sm mt-1 opacity-50`}></i>
                                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(roll.die3 as number)-1]} text-sm mt-1 opacity-50`}></i>
                                        <i class={`fa-solid fa-dice-${['one','two','three','four','five','six'][(roll.die4 as number)-1]} text-sm mt-1 opacity-50`}></i>
                                    </div>
                                    <div class={`font-bold w-40 text-right ${isSafe ? 'text-secondary' : 'text-primary'}`}>
                                        {chore.emoji} {chore.label}
                                    </div>
                                </div>
                            </div>
                        )
                    })}
                </div>
            )}
        </section>
    </div>
</Layout>
