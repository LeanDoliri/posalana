---
import Layout from '../layouts/Layout.astro';
import db from '../db/index.js';
import { getSeasonId, getExemptionsForSeason } from '../utils/season.js';
import UserAvatar from '../components/UserAvatar.astro';
import DiceDisplay from '../components/DiceDisplay.astro';

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

const user = Astro.locals.user;

// Get today's date in GMT-3
const today = new Date();
today.setHours(today.getHours() - 3);
const dateStr = today.toISOString().split('T')[0];

// Check if user rolled
const userRollRes = await db.execute({
    sql: "SELECT * FROM roll WHERE user_id = ? AND date = ?",
    args: [user.id, dateStr]
});
const hasRolled = userRollRes.rows.length > 0;
const myRoll = hasRolled ? userRollRes.rows[0] : null;

// Get all rolls for today, ordered by rules
const allRollsRes = await db.execute({
    sql: `
        SELECT r.*, u.username, u.display_name, u.avatar_url 
        FROM roll r
        JOIN user u ON r.user_id = u.id
        WHERE r.date = ?
        ORDER BY r.die1 ASC, r.die2 ASC, r.die3 ASC, r.die4 ASC
    `,
    args: [dateStr]
});
const allRolls = allRollsRes.rows;

const chores = [
    { label: "Lava los platos", code: "LA", emoji: "🧽" },
    { label: "Saca la mesa", code: "SA", emoji: "🧹" },
    { label: "Pone la mesa", code: "PO", emoji: "🍴" }
];
const safeChore = { label: "Nada", code: "NA", emoji: "🎉" };

import { assignDailyChores } from '../utils/chores.js';

// Fetch exemptions
const seasonId = getSeasonId(dateStr);
const exemptions = await getExemptionsForSeason(db, seasonId);

const { rollChoreMap, lomitoActivated, lomitoPlayers, sortedRolls } = assignDailyChores(allRolls, exemptions);
---
<Layout>
    <div class="space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-700 ease-out">
        
        <!-- Hero Section -->
        {hasRolled && myRoll ? (
            <section class="relative bg-white border border-foreground/10 p-4 md:p-6 rounded-2xl shadow-md overflow-hidden flex flex-col sm:flex-row items-center justify-between">
                <div class="text-center sm:text-left mb-4 sm:mb-0">
                    <p class="text-secondary font-bold tracking-widest uppercase text-[10px] mb-1">Tirada del {dateStr}</p>
                    <p class="text-sm text-foreground/80 font-medium">Ya cumpliste con tu destino de hoy.</p>
                </div>
                <div class="flex items-center gap-3 bg-secondary/5 border border-secondary/20 px-4 py-2 rounded-xl shadow-inner">
                    <p class="text-xs text-secondary font-bold uppercase tracking-wider mr-2 hidden md:block">Tu Suerte:</p>
                    <DiceDisplay die1={myRoll.die1 as number} die2={myRoll.die2 as number} die3={myRoll.die3 as number} die4={myRoll.die4 as number} size="lg" />
                </div>
            </section>
        ) : (
            <section class="relative bg-white border border-foreground/10 p-8 md:p-12 rounded-3xl shadow-xl overflow-hidden text-center group">
                <!-- Decorative Background Element -->
                <div class="absolute -top-24 -right-24 w-64 h-64 bg-secondary/10 rounded-full blur-3xl group-hover:bg-secondary/20 transition-all duration-700 pointer-events-none"></div>
                <div class="absolute -bottom-24 -left-24 w-64 h-64 bg-accent/10 rounded-full blur-3xl group-hover:bg-accent/20 transition-all duration-700 pointer-events-none"></div>

                <div class="relative z-10">
                    <p class="text-secondary font-bold tracking-widest uppercase text-xs mb-2">Tirada Oficial</p>
                    <h2 class="text-4xl md:text-5xl font-black mb-2 tracking-tight text-foreground text-balance">{dateStr}</h2>
                    <p class="text-foreground/60 mb-10 max-w-md mx-auto text-pretty">El destino no está escrito, se decide con los dados. ¿Zafás o lavás?</p>

                    <form method="post" action="/api/roll">
                        <button type="submit" class="relative overflow-hidden bg-secondary text-background px-10 py-5 rounded-full text-xl font-bold shadow-[0_8px_30px_rgba(0,204,204,0.3)] hover:shadow-[0_8px_40px_rgba(0,204,204,0.5)] hover:-translate-y-1 active:translate-y-0 active:shadow-[0_4px_15px_rgba(0,204,204,0.3)] transition-all duration-300 cursor-pointer group">
                            <span class="relative z-10 flex items-center justify-center gap-3">
                                <i class="fa-solid fa-dice text-2xl group-hover:rotate-180 transition-transform duration-500"></i>
                                TIRAR LOS DADOS
                            </span>
                            <!-- Hover gradient overlay -->
                            <div class="absolute inset-0 bg-gradient-to-r from-transparent via-background/20 to-transparent -translate-x-full group-hover:animate-[shimmer_1.5s_infinite]"></div>
                        </button>
                    </form>
                </div>
            </section>
        )}

        <!-- Cláusula Lomito -->
        <div id="lomito-container">
            {lomitoActivated && (
                <>
                    <section class="bg-white border-2 border-accent/60 p-8 rounded-3xl shadow-lg shadow-accent/10 text-center relative overflow-hidden animate-in zoom-in-95 duration-500">
                        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiNDQzY2RkYiIGZpbGwtb3BhY2l0eT0iMC4xIi8+PC9zdmc+')] opacity-50"></div>
                        <div class="relative z-10">
                            <p class="text-5xl mb-4 animate-bounce">🥪🎉🥪</p>
                            <h3 class="text-2xl md:text-3xl font-black text-accent mb-2 tracking-tight text-balance">¡CLÁUSULA LOMITO ACTIVADA!</h3>
                            <p class="text-accent/90 text-lg md:text-xl font-semibold mb-1 text-pretty">{lomitoPlayers.join(" y ")} rompieron la matrix.</p>
                            <p class="text-foreground/70 font-medium text-pretty">Sus dados son idénticos. ¡Hoy se almuerzan lomitos con papas!</p>
                        </div>
                    </section>
                    <script is:inline src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
                    <script is:inline>
                        // Lanza confetti durante 5 segundos
                        const duration = 5 * 1000;
                        const animationEnd = Date.now() + duration;
                        const defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 100 };

                        function randomInRange(min, max) {
                            return Math.random() * (max - min) + min;
                        }

                        const interval = setInterval(function() {
                            const timeLeft = animationEnd - Date.now();

                            if (timeLeft <= 0) {
                                return clearInterval(interval);
                            }

                            const particleCount = 50 * (timeLeft / duration);
                            confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
                            confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
                        }, 250);
                    </script>
                </>
            )}
        </div>

        <!-- Ranking Section -->
        <section id="ranking-container" class="bg-white border border-foreground/10 p-6 md:p-10 rounded-3xl shadow-xl">
            <div class="flex items-center justify-between mb-8 pb-4 border-b border-foreground/5">
                <h3 class="text-2xl font-black tracking-tight text-foreground flex items-center gap-3 text-balance">
                    <i class="fa-solid fa-trophy text-secondary"></i> Ranking POSALANA
                </h3>
            </div>
            
            {allRolls.length === 0 ? (
                <div class="py-16 text-center border-2 border-dashed border-foreground/10 rounded-2xl">
                    <div class="text-4xl mb-4 text-foreground/20"><i class="fa-solid fa-ghost"></i></div>
                    <p class="text-foreground/50 font-medium text-lg">Nadie se ha atrevido a tirar todavía.</p>
                </div>
            ) : (
                <div class="grid grid-cols-1 gap-4">
                    {sortedRolls.map((roll, index) => {
                        const chore = rollChoreMap.get(roll.id);
                        const isSafe = chore.code === "NA";
                        const userExemptions = exemptions.filter(e => String(e.user_id) === String(roll.user_id));
                        return (
                            <div class={`group flex flex-col sm:flex-row sm:items-center justify-between p-5 rounded-2xl border transition-all duration-300 hover:shadow-md ${isSafe ? 'bg-secondary/5 border-secondary/10 hover:border-secondary/30' : 'bg-primary/5 border-primary/10 hover:border-primary/30'}`}>
                                
                                <!-- User Info & Time -->
                                <div class="flex items-center gap-4 mb-4 sm:mb-0 w-full sm:w-auto">
                                    <UserAvatar user={roll as any} size="lg" border={true} />
                                    <div class="flex-grow">
                                        <div class="flex flex-wrap items-center gap-2">
                                            <p class="font-black text-foreground text-xl leading-tight">{roll.display_name}</p>
                                            <span class={`inline-block text-[10px] uppercase tracking-widest font-bold px-2 py-0.5 rounded-full ${isSafe ? 'bg-secondary text-background' : 'bg-primary text-background'}`}>
                                                {chore.code}
                                            </span>
                                            {userExemptions.map(ex => {
                                                const targetChore = chores.find(c => c.code === ex.chore_code);
                                                const choreLabel = targetChore ? targetChore.label.split(' ')[0] : ex.chore_code;
                                                return (
                                                    <span class="inline-flex items-center gap-1 text-[9px] font-black tracking-wider uppercase bg-accent/10 text-accent border border-accent/20 px-2 py-0.5 rounded-md" title={`Exento de: ${targetChore ? targetChore.label : ex.chore_code}`}>
                                                        <i class="fa-solid fa-shield-halved text-[8px]"></i> Exento {choreLabel}
                                                    </span>
                                                )
                                            })}
                                        </div>
                                        {roll.time && <span class="text-xs font-mono text-foreground/40 bg-foreground/5 px-2 py-0.5 rounded-md"><i class="fa-regular fa-clock"></i> {roll.time}</span>}
                                        <div class={`font-bold mt-1 text-sm ${isSafe ? 'text-secondary' : 'text-primary'} whitespace-nowrap`}>
                                            {chore.emoji} {chore.label}
                                        </div>
                                    </div>
                                </div>

                                <div class="flex items-center justify-center sm:justify-end bg-white/50 sm:bg-transparent p-4 sm:p-0 rounded-xl w-full sm:w-auto mt-2 sm:mt-0">
                                    <DiceDisplay die1={roll.die1 as number} die2={roll.die2 as number} die3={roll.die3 as number} die4={roll.die4 as number} size="xl" isSafe={isSafe} />
                                </div>
                            </div>
                        )
                    })}
                </div>
            )}
        </section>

        <!-- Client-side Polling Script -->
        <script is:inline>
            // Polling interval in milliseconds (8 seconds)
            const POLL_INTERVAL = 8000;
            let intervalId = null;

            async function checkUpdates() {
                try {
                    const response = await fetch(window.location.href);
                    if (!response.ok) return;
                    
                    const text = await response.text();
                    const parser = new DOMParser();
                    const doc = parser.parseFromString(text, "text/html");

                    // 1. Update Ranking
                    const newRanking = doc.getElementById("ranking-container");
                    const oldRanking = document.getElementById("ranking-container");
                    if (newRanking && oldRanking && newRanking.innerHTML !== oldRanking.innerHTML) {
                        oldRanking.innerHTML = newRanking.innerHTML;
                    }

                    // 2. Update Lomito Banner and check for new Lomito activation
                    const newLomito = doc.getElementById("lomito-container");
                    const oldLomito = document.getElementById("lomito-container");
                    if (newLomito && oldLomito && newLomito.innerHTML !== oldLomito.innerHTML) {
                        const hadLomito = oldLomito.querySelector("section") !== null;
                        const hasLomito = newLomito.querySelector("section") !== null;
                        
                        oldLomito.innerHTML = newLomito.innerHTML;

                        // Trigger confetti if Lomito just got activated
                        if (!hadLomito && hasLomito) {
                            triggerConfetti();
                        }
                    }
                } catch (error) {
                    console.error("Error checking for updates:", error);
                }
            }

            function triggerConfetti() {
                if (typeof window.confetti === "function") {
                    runConfetti();
                } else {
                    const script = document.createElement("script");
                    script.src = "https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js";
                    script.onload = runConfetti;
                    document.body.appendChild(script);
                }
            }

            function runConfetti() {
                const duration = 5 * 1000;
                const animationEnd = Date.now() + duration;
                const defaults = { startVelocity: 30, spread: 360, ticks: 60, zIndex: 100 };

                function randomInRange(min, max) {
                    return Math.random() * (max - min) + min;
                }

                const interval = setInterval(() => {
                    const timeLeft = animationEnd - Date.now();
                    if (timeLeft <= 0) {
                        return clearInterval(interval);
                    }
                    const particleCount = 50 * (timeLeft / duration);
                    window.confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.1, 0.3), y: Math.random() - 0.2 } }));
                    window.confetti(Object.assign({}, defaults, { particleCount, origin: { x: randomInRange(0.7, 0.9), y: Math.random() - 0.2 } }));
                }, 250);
            }

            // Start polling only if the page is visible
            function startPolling() {
                if (!intervalId) {
                    intervalId = setInterval(checkUpdates, POLL_INTERVAL);
                }
            }

            // Stop polling to save resources
            function stopPolling() {
                if (intervalId) {
                    clearInterval(intervalId);
                    intervalId = null;
                }
            }

            // Page Visibility API integration
            function handleVisibilityChange() {
                if (document.hidden) {
                    stopPolling();
                } else {
                    // Check immediately when page becomes visible, then restart interval
                    checkUpdates();
                    startPolling();
                }
            }

            // Initialization
            if (typeof document !== "undefined") {
                document.addEventListener("visibilitychange", handleVisibilityChange);
                if (!document.hidden) {
                    startPolling();
                }
            }
        </script>
    </div>
</Layout>
