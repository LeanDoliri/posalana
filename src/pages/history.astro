---
import Layout from '../layouts/Layout.astro';
import db from '../db/index.js';
import UserAvatar from '../components/UserAvatar.astro';
import DiceDisplay from '../components/DiceDisplay.astro';

if (!Astro.locals.user) {
	return Astro.redirect('/login');
}

// Get all rolls ordered by date descending, then by die scores ascending
const allRollsRes = await db.execute(`
    SELECT r.*, u.username, u.display_name, u.avatar_url 
    FROM roll r
    JOIN user u ON r.user_id = u.id
    ORDER BY r.date DESC, r.die1 ASC, r.die2 ASC, r.die3 ASC, r.die4 ASC
`);

// Group by date
const groupedRolls: Record<string, typeof allRollsRes.rows> = {};
for (const row of allRollsRes.rows) {
    const date = row.date as string;
    if (!groupedRolls[date]) {
        groupedRolls[date] = [];
    }
    groupedRolls[date].push(row);
}

import { getSeasonId, getPreviousSeasons, formatSeasonName, calculateSeasonPoints, calculateYearPoints } from '../utils/season.js';
import { assignDailyChores } from '../utils/chores.js';

const dates = Object.keys(groupedRolls).sort((a, b) => b.localeCompare(a));

// Fetch all exemptions
const allExemptionsRes = await db.execute("SELECT * FROM exemption");
const allExemptions = allExemptionsRes.rows;

const historyData = dates.map(date => {
    const seasonId = getSeasonId(date);
    const seasonExemptions = allExemptions.filter(e => e.season_id === seasonId);
    
    const { sortedRolls, rollChoreMap, lomitoActivated, lomitoPlayers } = assignDailyChores(groupedRolls[date], seasonExemptions);
    
    return {
        date,
        rolls: sortedRolls,
        choreMap: rollChoreMap,
        lomitoActivated,
        lomitoPlayers
    };
});

// Calculate current date in GMT-3 to obtain current season
const today = new Date();
today.setHours(today.getHours() - 3);
const todayStr = today.toISOString().split('T')[0];
const currentSeasonId = getSeasonId(todayStr);
const prevSeasonId = getPreviousSeasons(currentSeasonId, 1)[1];

const currentSeasonStats = await calculateSeasonPoints(db, currentSeasonId);
const prevSeasonStats = await calculateSeasonPoints(db, prevSeasonId);

// Sort alphabetically by display_name (falling back to username)
const sortStats = (stats: any[]) => {
    return [...stats].sort((a, b) => {
        const nameA = String(a.display_name || a.username);
        const nameB = String(b.display_name || b.username);
        return nameA.localeCompare(nameB);
    });
};

const sortedCurrentStats = sortStats(currentSeasonStats);
const sortedPrevStats = sortStats(prevSeasonStats);

const currentYear = today.getFullYear().toString();
const yearStats = await calculateYearPoints(db, currentYear);
const sortedYearStats = sortStats(yearStats);
---

<Layout>
    <div class="space-y-10 animate-in fade-in slide-in-from-bottom-4 duration-700 ease-out">
        
        <header class="mb-10 text-center md:text-left flex flex-col md:flex-row justify-between items-center gap-4">
            <div>
                <h2 class="text-3xl md:text-4xl font-black tracking-tight text-foreground">Archivos POSALANA</h2>
                <p class="text-foreground/60 mt-2">El registro inmutable de la suerte pasada.</p>
            </div>
            <div class="bg-foreground/5 px-4 py-2 rounded-full text-sm font-bold text-foreground/70">
                <i class="fa-solid fa-database mr-2"></i> {dates.length} días registrados
            </div>
        </header>

        <!-- Resumen de Temporadas -->
        <section class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <!-- Temporada Actual -->
            <div class="bg-background border border-foreground/10 p-6 md:p-8 rounded-3xl shadow-lg relative overflow-hidden group">
                <div class="absolute -top-12 -right-12 w-36 h-36 bg-secondary/5 rounded-full blur-2xl group-hover:bg-secondary/10 transition-all duration-500 pointer-events-none"></div>
                
                <h3 class="text-xl font-black mb-6 flex items-center gap-2.5 text-foreground relative z-10">
                    <i class="fa-solid fa-calendar-days text-secondary"></i>
                    Temporada Actual: <span class="text-secondary">{formatSeasonName(currentSeasonId)}</span>
                </h3>
                
                {sortedCurrentStats.length === 0 ? (
                    <p class="text-sm text-foreground/50 py-8 italic text-center">Sin datos registrados en esta temporada.</p>
                ) : (
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse text-sm">
                            <thead>
                                <tr class="border-b border-foreground/10 text-foreground/50 text-[10px] uppercase tracking-widest font-black">
                                    <th class="pb-3 font-black">Jugador</th>
                                    <th class="pb-3 text-center font-black">🧽 LA</th>
                                    <th class="pb-3 text-center font-black">🗑️ SA</th>
                                    <th class="pb-3 text-center font-black">🍽️ PO</th>
                                    <th class="pb-3 text-center font-black text-secondary">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-foreground/5">
                                {sortedCurrentStats.map(stat => (
                                    <tr class="hover:bg-foreground/[0.01] transition-colors">
                                        <td class="py-3 pr-2">
                                            <div class="flex items-center gap-2.5">
                                                <UserAvatar user={{ username: stat.username, display_name: stat.display_name, avatar_url: stat.avatar_url }} size="sm" />
                                                <span class="font-bold text-foreground">{stat.display_name}</span>
                                            </div>
                                        </td>
                                        <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.LA}</td>
                                        <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.SA}</td>
                                        <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.PO}</td>
                                        <td class="py-3 text-center font-mono font-black text-secondary bg-secondary/5 rounded-lg">{stat.scores.LA + stat.scores.SA + stat.scores.PO}</td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                )}
            </div>

            <!-- Temporada Anterior -->
            <div class="bg-background border border-foreground/10 p-6 md:p-8 rounded-3xl shadow-lg relative overflow-hidden group">
                <div class="absolute -top-12 -right-12 w-36 h-36 bg-accent/5 rounded-full blur-2xl group-hover:bg-accent/10 transition-all duration-500 pointer-events-none"></div>
                
                <h3 class="text-xl font-black mb-6 flex items-center gap-2.5 text-foreground relative z-10">
                    <i class="fa-solid fa-clock-rotate-left text-accent"></i>
                    Temporada Anterior: <span class="text-accent">{formatSeasonName(prevSeasonId)}</span>
                </h3>
                
                {sortedPrevStats.length === 0 ? (
                    <p class="text-sm text-foreground/50 py-8 italic text-center">Sin datos registrados en la temporada anterior.</p>
                ) : (
                    <div class="overflow-x-auto">
                        <table class="w-full text-left border-collapse text-sm">
                            <thead>
                                <tr class="border-b border-foreground/10 text-foreground/50 text-[10px] uppercase tracking-widest font-black">
                                    <th class="pb-3 font-black">Jugador</th>
                                    <th class="pb-3 text-center font-black">🧽 LA</th>
                                    <th class="pb-3 text-center font-black">🗑️ SA</th>
                                    <th class="pb-3 text-center font-black">🍽️ PO</th>
                                    <th class="pb-3 text-center font-black text-accent">TOTAL</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-foreground/5">
                                {sortedPrevStats.map(stat => (
                                    <tr class="hover:bg-foreground/[0.01] transition-colors">
                                        <td class="py-3 pr-2">
                                            <div class="flex items-center gap-2.5">
                                                <UserAvatar user={{ username: stat.username, display_name: stat.display_name, avatar_url: stat.avatar_url }} size="sm" />
                                                <span class="font-bold text-foreground">{stat.display_name}</span>
                                            </div>
                                        </td>
                                        <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.LA}</td>
                                        <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.SA}</td>
                                        <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.PO}</td>
                                        <td class="py-3 text-center font-mono font-black text-accent bg-accent/5 rounded-lg">{stat.scores.LA + stat.scores.SA + stat.scores.PO}</td>
                                    </tr>
                                ))}
                            </tbody>
                        </table>
                    </div>
                )}
            </div>
        </section>

        <!-- Tabla Global del Año -->
        <div class="bg-background border border-foreground/10 p-6 md:p-8 rounded-3xl shadow-lg relative overflow-hidden group">
            <div class="absolute -top-12 -right-12 w-48 h-48 bg-primary/5 rounded-full blur-3xl group-hover:bg-primary/10 transition-all duration-500 pointer-events-none"></div>
            
            <h3 class="text-xl font-black mb-6 flex items-center gap-2.5 text-foreground relative z-10">
                <i class="fa-solid fa-earth-americas text-primary"></i>
                Tabla Global del Año: <span class="text-primary">{currentYear}</span>
            </h3>
            
            {sortedYearStats.length === 0 ? (
                <p class="text-sm text-foreground/50 py-8 italic text-center">Sin datos registrados en este año.</p>
            ) : (
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse text-sm">
                        <thead>
                            <tr class="border-b border-foreground/10 text-foreground/50 text-[10px] uppercase tracking-widest font-black">
                                <th class="pb-3 font-black">Jugador</th>
                                <th class="pb-3 text-center font-black">🧽 LA (Lava)</th>
                                <th class="pb-3 text-center font-black">🗑️ SA (Saca)</th>
                                <th class="pb-3 text-center font-black">🍽️ PO (Pone)</th>
                                <th class="pb-3 text-center font-black text-primary">TOTAL GLOBAL</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-foreground/5">
                            {sortedYearStats.map(stat => (
                                <tr class="hover:bg-foreground/[0.01] transition-colors">
                                    <td class="py-3 pr-2">
                                        <div class="flex items-center gap-2.5">
                                            <UserAvatar user={{ username: stat.username, display_name: stat.display_name, avatar_url: stat.avatar_url }} size="sm" />
                                            <span class="font-bold text-foreground">{stat.display_name}</span>
                                        </div>
                                    </td>
                                    <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.LA}</td>
                                    <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.SA}</td>
                                    <td class="py-3 text-center font-mono font-bold text-foreground/80">{stat.scores.PO}</td>
                                    <td class="py-3 text-center font-mono font-black text-primary bg-primary/5 rounded-lg px-2">{stat.scores.LA + stat.scores.SA + stat.scores.PO}</td>
                                </tr>
                            ))}
                        </tbody>
                    </table>
                </div>
            )}
        </div>

        {dates.length === 0 ? (
            <div class="py-20 text-center border-2 border-dashed border-foreground/10 rounded-3xl">
                <div class="text-5xl mb-4 text-foreground/20"><i class="fa-solid fa-folder-open"></i></div>
                <p class="text-foreground/60 font-medium text-lg">Los archivos están vacíos.</p>
            </div>
        ) : (
            <div class="space-y-12">
                {historyData.map((data, dateIndex) => (
                    <section class="relative">
                        <!-- Timeline visual connector -->
                        {dateIndex !== dates.length - 1 && (
                            <div class="absolute left-[1.3rem] md:left-[1.8rem] top-14 bottom-[-3rem] w-px bg-foreground/10 z-0"></div>
                        )}
                        
                        <!-- Date Header -->
                        <div class="flex items-center gap-4 mb-6 relative z-10">
                            <div class="w-10 h-10 md:w-14 md:h-14 rounded-full bg-secondary text-background flex items-center justify-center font-black shadow-lg">
                                <i class="fa-solid fa-calendar-day"></i>
                            </div>
                            <h3 class="text-xl md:text-2xl font-black text-foreground">{data.date}</h3>
                        </div>

                        <!-- Lomito Indicator -->
                        {data.lomitoActivated && (
                            <div class="pl-6 md:pl-10 mb-4 relative z-10">
                                <div class="bg-accent/10 border border-accent/20 px-4 py-2 rounded-xl inline-block">
                                    <span class="text-accent font-bold text-sm">🥪 Cláusula Lomito activada por {data.lomitoPlayers.join(" y ")}</span>
                                </div>
                            </div>
                        )}

                        <!-- Rolls Grid -->
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 pl-6 md:pl-10 relative z-10">
                            {data.rolls.map((roll, index) => {
                                const chore = data.choreMap.get(roll.id);
                                const isSafe = chore.code === "NA";
                                return (
                                    <div class={`group flex flex-row items-center justify-between p-4 rounded-2xl border transition-all duration-300 hover:shadow-md hover:-translate-y-0.5 ${isSafe ? 'bg-background border-foreground/10 hover:border-secondary/30' : 'bg-primary/5 border-primary/10 hover:border-primary/30'}`}>
                                        
                                        <!-- User -->
                                        <div class="flex items-center gap-3">
                                            <UserAvatar user={{ username: roll.username as string, display_name: roll.display_name as string, avatar_url: roll.avatar_url as string }} size="md" />
                                            <span class="font-bold text-foreground">{roll.display_name}</span>
                                        </div>

                                        <!-- Stats -->
                                        <div class="flex items-center gap-4">
                                            <div class="hidden sm:flex items-center opacity-70 group-hover:opacity-100 transition-opacity">
                                                <DiceDisplay die1={roll.die1 as number} die2={roll.die2 as number} die3={roll.die3 as number} die4={roll.die4 as number} size="sm" isSafe={isSafe} />
                                            </div>
                                            <div class={`px-3 py-1 rounded-lg text-xs font-black tracking-widest ${isSafe ? 'bg-secondary text-background' : 'bg-primary text-background shadow-[0_0_10px_rgba(234,42,88,0.3)]'}`}>
                                                {chore.code}
                                            </div>
                                        </div>
                                    </div>
                                )
                            })}
                        </div>
                    </section>
                ))}
            </div>
        )}
    </div>
</Layout>
