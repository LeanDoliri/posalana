---
export interface Props {
    user: {
        username: string;
        display_name?: string | null;
        avatar_url?: string | null;
    };
    size?: "sm" | "md" | "lg" | "xl";
    border?: boolean;
}

const { user, size = "md", border = false } = Astro.props;

const sizeClasses = {
    sm: "w-6 h-6 text-[10px]",
    md: "w-10 h-10 text-sm",
    lg: "w-16 h-16 text-xl",
    xl: "w-32 h-32 text-4xl"
};

const hasAvatar = user.avatar_url && user.avatar_url !== 'null';
const name = user.display_name || user.username;
const initial = name ? name.charAt(0).toUpperCase() : '?';
---

<div class={`${sizeClasses[size]} rounded-full bg-secondary/10 flex items-center justify-center font-bold text-secondary overflow-hidden ${border ? 'border-2 border-secondary/20 shadow-sm' : ''}`}>
    {hasAvatar ? (
        <img src={user.avatar_url as string} alt={name} class="w-full h-full object-cover" referrerpolicy="no-referrer" />
    ) : (
        initial
    )}
</div>
